{
  "manifest_version": 3,
  "name": "OmniFetch by BungsuDev",
  "version": "2.0.0",
  "description": "Intercept, record, and automate HTTP requests with smart redirect tracking and browser automation recorder.",
  "permissions": [
    "webRequest",
    "webNavigation",
    "tabs",
    "activeTab",
    "storage",
    "cookies",
    "debugger",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "OmniFetch by BungsuDev"
  },
  "devtools_page": "devtools.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js", "recorder.js", "player.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
